<div class="archive-page">
  <h1 class="archive-title">
    <%= __('archive.title') %>
  </h1>

  <% 
  var posts = (page.posts || site.posts);
  var years = {};
  if (posts && (posts.length > 0 || (posts.count && posts.count() > 0))) {
    var postsArray = posts.toArray ? posts.toArray() : posts;
    postsArray.sort(function(a, b) { return b.date - a.date; }).forEach(function(post) {
      var year = post.date.year();
      if (!years[year]) { years[year] = []; }
      years[year].push(post);
    });
  }
  var sortedYears = Object.keys(years).sort(function(a, b) { return b - a; }); 
  %>

    <% sortedYears.forEach(function(year) { %>
      <section class="archive-year">
        <h2 class="archive-year-title">
          <%= year %>
        </h2>
        <ul class="archive-posts">
          <% years[year].forEach(function(post) { %>
            <li class="archive-post-item">
              <span class="archive-post-date">
                <%= date(post.date, 'MM-DD' ) %>
              </span>
              <a href="<%- url_for(post.path) %>" class="archive-post-link">
                <% if (post.categories && post.categories.length > 1) { %>
                  <span class="post-ctf-name" style="color: #6e6e6e; font-size: 0.85rem; margin-right: 5px;">[<%= post.categories.data[1].name %>]</span>
                <% } %>
                <%= post.title || '(Untitled)' %>
              </a>
            </li>
            <% }); %>
        </ul>
      </section>
      <% }); %>

        <%- partial('_partial/pagination') %>
</div>