<%
var layout = theme.columns.layout || 'two-column';
var items = theme.columns.items || [];
%>

<div class="columns-container columns-<%= layout %>">
  <% items.forEach(function(column, index) { %>
    <section class="column column-<%= index %>">
      <h2 class="column-title">
        <% 
        var targetCat = site.categories.findOne({name: column.category});
        %>
        <a href="<%- url_for(targetCat ? targetCat.path : '/categories/' + column.category.toLowerCase().replace(/ /g, '-') + '/') %>">
          <%= column.name %>
        </a>
      </h2>

      <ul class="column-posts">
        <%
        // Convert to array and filter posts by category
        var categoryName = column.category.toLowerCase();
        var allPosts = site.posts.toArray ? site.posts.toArray() : (site.posts || []);
        
        var categoryPosts = allPosts.filter(function(post) {
          if (!post.categories || post.categories.length === 0) return false;
          var cats = post.categories.toArray ? post.categories.toArray() : post.categories;
          return cats.some(function(cat) {
            var catName = cat.name || "";
            var catSlug = cat.slug || "";
            return catName.toLowerCase() === categoryName ||
                   catSlug.toLowerCase() === categoryName.replace(/ /g, '-');
          });
        }).sort(function(a, b) { return b.date - a.date; });

        var limit = column.limit || 10;
        var displayPosts = categoryPosts.slice(0, limit);

        if (displayPosts && displayPosts.length > 0) {
          displayPosts.forEach(function(post) {
        %>
          <li class="column-post-item">
            <a href="<%- url_for(post.path) %>" class="post-link">
              <% 
              var postCats = post.categories.toArray ? post.categories.toArray() : (post.categories.data || []);
              if (postCats.length > 1) { 
              %>
                <span class="post-ctf-name" style="color: #6e6e6e; font-size: 0.85rem; margin-right: 5px;">[<%= postCats[1].name %>]</span>
              <% } %>
              <%= post.title || '(Untitled)' %>
            </a>
            <% if (column.show_date !== false) { %>
              <span class="post-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
            <% } %>
          </li>
        <%
          });
        } else {
        %>
          <li class="no-posts">No posts in this category yet.</li>
        <% } %>
      </ul>

      <% if (categoryPosts.length > limit) { %>
        <a href="<%- url_for(targetCat ? targetCat.path : '/categories/' + column.category.toLowerCase().replace(/ /g, '-') + '/') %>" class="view-all">
          View All (<%= categoryPosts.length %>) &rarr;
        </a>
      <% } %>
    </section>
  <% }); %>
</div>
