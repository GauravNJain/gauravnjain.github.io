<div class="categories-page">
  <h1 class="page-title">
    <%= page.title || __('nav.categories') %>
  </h1>

  <% 
  var categories = site.categories;
  if (categories && (categories.length > 0 || (categories.count && categories.count() > 0))) { 
    var categoriesArray = categories.toArray ? categories.toArray() : categories;
    var rootCategories = categoriesArray.filter(function(c){ return !c.parent; }).sort(function(a, b){
      return a.name.localeCompare(b.name);
    });
  %>
    <div class="categories-list">
      <% rootCategories.forEach(function(category) { %>
        <a href="<%- url_for(category.path) %>" class="category-item">
          <%= category.name %>
            <span class="count">(<%= category.posts.length %>)</span>
        </a>
        <% }); %>
    </div>

    <div class="categories-posts">
      <% rootCategories.forEach(function(category) { %>
        <section class="category-section" id="<%= category.slug %>">
          <h2 class="category-name">
            <a href="<%- url_for(category.path) %>">
              <%= category.name %>
            </a>
            <span class="count">
              <%= category.posts.length %> posts
            </span>
          </h2>
          <ul class="category-post-list">
            <% 
            var catPosts = category.posts.toArray().sort(function(a, b){ return b.date - a.date; }).slice(0, 10);
            catPosts.forEach(function(post) { 
            %>
              <li class="category-post-item">
                <span class="post-date">
                  <%= date(post.date, 'YYYY-MM-DD' ) %>
                </span>
                <a href="<%- url_for(post.path) %>" class="post-link">
                  <% if (post.categories && post.categories.length > 1) { %>
                    <span class="post-ctf-name" style="color: #6e6e6e; font-size: 0.85rem; margin-right: 5px;">[<%= post.categories.data[1].name %>]</span>
                  <% } %>
                  <%= post.title %>
                </a>
              </li>
              <% }); %>
          </ul>
        </section>
        <% }); %>
    </div>
    <% } else { %>
      <p class="no-data">No categories yet.</p>
      <% } %>
</div>